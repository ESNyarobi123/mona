# ===== Database =====
# Option A - Docker (docker compose up -d):
#   postgresql://postgres:password@localhost:5432/monana?schema=public
# Option B - Local Homebrew Postgres (superuser = your macOS user, no password):
#   postgresql://<your-mac-user>@localhost:5432/monana?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/monana?schema=public"

# ===== Auth =====
AUTH_SECRET="change-me-to-a-long-random-string"
JWT_SECRET="change-me-too"

# ===== Next.js Web =====
NEXT_PUBLIC_APP_URL="http://localhost:3000"
API_BASE_URL="http://localhost:3000/api"
# Customer-facing WhatsApp on landing page (optional fallback if bot status unavailable)
NEXT_PUBLIC_WHATSAPP_NUMBER=""

# ===== WhatsApp Bot (Baileys) =====
BOT_SESSION_PATH="./session"
BOT_PORT="4000"
# URL the web API uses to push WhatsApp messages through the bot bridge.
BOT_URL="http://localhost:4000"
# Admin personal WhatsApp — alerts: new user, new order, payment pending.
ADMIN_WHATSAPP_NUMBER="255750599412"
# After npm run db:seed:
#   Admin:    255700000000 / admin123
#   Customer: 255711111111 / demo1234 (sample orders; wallet UI disabled for now)

# ===== Payments (Manual MVP) =====
LIPA_NAMBA="XXXXXXX"
LIPA_NAMBA_NAME="MONANA"
# Future: ZenoPay / Flutterwave
ZENOPAY_API_KEY=""
FLUTTERWAVE_SECRET_KEY=""

# Cron: POST /api/grocery/subscriptions/run-due (header x-cron-secret)
CRON_SECRET="change-me-cron-secret"
