// Monana System - shared backend, two business modules:
//   RESTAURANT = Monana Food  |  GROCERY = Monana Market (grocery store)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== SHARED ENUMS =====================

enum Role {
  CUSTOMER
  ADMIN
  RIDER
}

/// Which side of Monana the order/catalog belongs to.
enum BusinessModule {
  RESTAURANT
  GROCERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  ON_THE_WAY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  AWAITING_CONFIRMATION
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MANUAL_LIPA_NAMBA
  QR
  ZENOPAY
  FLUTTERWAVE
  WALLET
}

enum PaymentTiming {
  PAY_NOW
  PAY_ON_DELIVERY
}

enum Channel {
  WEB
  WHATSAPP
}

// ===================== RESTAURANT (Monana Food) =====================

enum MealSlot {
  BREAKFAST // asubuhi
  LUNCH     // mchana
  DINNER    // usiku
}

enum KitchenQueueStatus {
  WAITING
  COOKING
  READY
  SERVED
}

// ===================== GROCERY (Monana Market) =====================

enum SubscriptionFrequency {
  WEEKLY
  MONTHLY
}

enum SubscriptionStatus {
  PENDING_PAYMENT
  ACTIVE
  PAUSED
  CANCELLED
}

/// Aina ya kifurushi cha usajili
enum PackageKind {
  WEEKLY_BASKET  // Kifurushi cha Wiki — mboga, matunda, mahitaji ya msingi
  MONTHLY_PANTRY // Kifurushi cha Mwezi — nafaka, mafuta, sukari, n.k.
}

/// Grocery order tier: papo kwa papo vs subscription delivery
enum GroceryOrderType {
  ON_DEMAND
  SUBSCRIPTION
}

/// Admin: auto algorithm vs hand-picked hot/trending items
enum HotPickMode {
  AUTO
  MANUAL
}

/// Daily market report batch (procurement + packing + routes)
enum MarketRunTrigger {
  MANUAL
  CRON
}

enum MarketRunStatus {
  OPEN
  LOCKED
  COMPLETED
}

// ===================== SHARED MODELS =====================

model User {
  id        String   @id @default(cuid())
  name      String?
  phone     String   @unique
  email     String?  @unique
  password  String?
  role      Role     @default(CUSTOMER)
  locale    String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders        Order[]
  wallet        Wallet?
  payments      Payment[]
  subscriptions GrocerySubscription[]
  restaurantSubscriptions RestaurantSubscription[]
  checkoutIntents CheckoutIntent[]
}

model Wallet {
  id        String   @id @default(cuid())
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  module    BusinessModule
  status    OrderStatus    @default(PENDING)
  channel   Channel        @default(WEB)
  /// Sum of line items (before delivery)
  subtotal  Decimal        @default(0) @db.Decimal(12, 2)
  deliveryFee Decimal      @default(0) @db.Decimal(12, 2)
  total     Decimal        @db.Decimal(12, 2)
  address   String?
  note      String?
  /// Restaurant: which meal window (asubuhi/mchana/usiku)
  mealSlot  MealSlot?
  /// Grocery tier (null for restaurant orders)
  orderType      GroceryOrderType?
  /// Grocery: link to a subscription delivery when applicable
  subscriptionId String?
  subscription   GrocerySubscription? @relation(fields: [subscriptionId], references: [id])
  scheduledFor   DateTime?
  /// Admin override for delivery route grouping (else inferred from address)
  deliveryZoneId String?
  deliveryZone   DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  paymentTiming  PaymentTiming  @default(PAY_NOW)
  /// Set when order is officially submitted (pay-now: on payment ref; pay-on-delivery: on admin approve)
  submittedAt    DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  items         OrderItem[]
  payment       Payment?
  kitchenQueue  KitchenQueue?
  packingChecks GroceryPackingCheck[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id])
  name      String
  unit      String   @default("PIECE")
  quantity  Decimal  @default(1) @db.Decimal(10, 3)
  price     Decimal  @db.Decimal(12, 2)
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String        @unique
  order     Order         @relation(fields: [orderId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod @default(MANUAL_LIPA_NAMBA)
  status    PaymentStatus @default(PENDING)
  reference String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

/// Holds order data until customer submits a payment reference (no Order row yet).
model CheckoutIntent {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  module       BusinessModule
  channel      Channel        @default(WEB)
  total        Decimal        @db.Decimal(12, 2)
  payload      Json
  /// Shown on Lipa Namba screen (MNA-xxx) — not the customer's M-Pesa code
  paymentToken String         @unique
  expiresAt    DateTime
  consumedAt   DateTime?
  orderId      String?        @unique
  createdAt    DateTime       @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model BotSession {
  id        String   @id @default(cuid())
  phone     String   @unique
  state     String   @default("IDLE")
  data      Json?
  updatedAt DateTime @updatedAt
}

/// Admin-editable platform settings (WhatsApp admin, Lipa Namba, …)
model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ===================== GROCERY MODULE =====================

/// Admin-managed sale units (kg, piece, custom …)
model UnitDefinition {
  id               String          @id @default(cuid())
  /// Uppercase code stored on products (e.g. KG, DOZEN)
  code             String          @unique
  labelEn          String
  labelSw          String
  /// Shown after price: TZS 3,000 / {priceSuffix}
  priceSuffix      String
  quantitySuffixEn String?
  quantitySuffixSw String?
  icon             String?
  /// null = shared across grocery & restaurant
  module           BusinessModule?
  isSystem         Boolean         @default(false)
  active           Boolean         @default(true)
  sortOrder        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Category {
  id        String         @id @default(cuid())
  name      String
  module    BusinessModule @default(GROCERY)
  products  Product[]
  menuItems MenuItem[]
  createdAt DateTime       @default(now())
}

/// Raw grocery items (mchele, sukari, mboga, …)
model Product {
  id          String         @id @default(cuid())
  name        String
  description String?
  /// Price per `unit` (e.g. per 1 kg or per 1 piece)
  price       Decimal        @db.Decimal(12, 2)
  unit        String         @default("PIECE")
  imageUrl    String?
  module      BusinessModule @default(GROCERY)
  available   Boolean        @default(true)
  /// Visible in store but not purchasable when false (out of stock)
  inStock     Boolean        @default(true)
  categoryId  String?
  category    Category?      @relation(fields: [categoryId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  orderItems OrderItem[]
  hotPicks   HotPickManual[]
}

/// Pre-built bundles (weekly/monthly grocery packs)
model GroceryPackage {
  id                 String         @id @default(cuid())
  name               String
  description        String?
  kind               PackageKind    @default(WEEKLY_BASKET)
  price              Decimal        @db.Decimal(12, 2)
  /// JSON: [{ productId, quantity }]
  items              Json
  /// Utoaji kwa mwezi: 1 au 2 (MONTHLY_PANTRY)
  deliveriesPerMonth Int            @default(1)
  /// Punguzo % kwa malipo ya mbele (mf. 5 = 5%)
  discountPercent    Decimal        @default(0) @db.Decimal(5, 2)
  /// Ofa: uwasilishaji bure
  freeDelivery       Boolean        @default(false)
  /// Saa kabla ya utoaji zinapofungwa mabadiliko ya kikapu
  orderCutoffHours   Int            @default(48)
  active             Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  subscriptions GrocerySubscription[]
}

model GrocerySubscription {
  id                 String                @id @default(cuid())
  userId             String
  user               User                  @relation(fields: [userId], references: [id])
  packageId          String
  package            GroceryPackage        @relation(fields: [packageId], references: [id])
  frequency          SubscriptionFrequency
  status             SubscriptionStatus    @default(ACTIVE)
  /// Delivery address for every cycle
  address            String
  channel            Channel               @default(WEB)
  /// 0=Jumapili … 6=Jumamosi (WEEKLY_BASKET)
  preferredDayOfWeek   Int?
  /// Siku ya mwezi 1–28 (MONTHLY_PANTRY)
  preferredDayOfMonth  Int?
  /// Utoaji wa pili kwa mwezi (mf. 15)
  secondaryDayOfMonth  Int?
  /// 1 au 2 utoaji kwa mwezi
  deliveriesPerMonth   Int            @default(1)
  note                 String?
  /// Sitisha hadi tarehe hii (safari, n.k.)
  pausedUntil          DateTime?
  /// Mabadiliko ya kikapu kwa utoaji ujao (kabla ya cutoff)
  nextDeliveryItems    Json?
  /// Kikapu cha msingi cha mteja (bidhaa zinazojirudia kila mzunguko)
  defaultBasket        Json?
  nextRunAt            DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  orders Order[]
}

/// Admin-defined delivery areas (Kinondoni, Masaki, …) — matched against order address
model DeliveryZone {
  id        String   @id @default(cuid())
  name      String
  nameSw    String?
  /// Lowercase keywords matched in normalized address text
  keywords  Json
  /// Delivery fee when pricing mode is ZONE (TZS)
  deliveryFee Decimal @default(0) @db.Decimal(12, 2)
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

/// Snapshot of all three market reports for one delivery day
model GroceryMarketRun {
  id               String            @id @default(cuid())
  /// Day we shop for / deliver (calendar date)
  deliveryDate     DateTime          @db.Date
  generatedAt      DateTime          @default(now())
  trigger          MarketRunTrigger  @default(MANUAL)
  status           MarketRunStatus   @default(OPEN)
  lockedAt         DateTime?
  orderCount       Int               @default(0)
  customerCount    Int               @default(0)
  /// Master procurement list (aggregated products)
  procurement      Json
  /// Per-customer packing checklists
  packing          Json
  /// Delivery stops grouped by zone
  routes           Json
  includedOrderIds String[]

  packingChecks GroceryPackingCheck[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deliveryDate])
  @@index([deliveryDate])
}

/// Tick-state for packing checklist (synced with packing JSON on run)
model GroceryPackingCheck {
  id          String           @id @default(cuid())
  runId       String
  run         GroceryMarketRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  orderId     String
  order       Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  /// [{ key, name, unit, quantity, checked }]
  lines       Json
  completedAt DateTime?
  updatedAt   DateTime          @updatedAt

  @@unique([runId, orderId])
}

// ===================== RESTAURANT MODULE =====================

/// Restaurant membership — customer picks meal slots (B/L/D) and gets WhatsApp reminders when each window opens.
model RestaurantSubscription {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id])
  mealSlots   MealSlot[]
  status      SubscriptionStatus @default(ACTIVE)
  address     String?
  channel     Channel            @default(WEB)
  pausedUntil DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([userId, status])
}

/// One reminder per user/slot/day (EAT calendar date).
model RestaurantSlotReminderLog {
  id      String   @id @default(cuid())
  userId  String
  slot    MealSlot
  eatDate String
  sentAt  DateTime @default(now())

  @@unique([userId, slot, eatDate])
  @@index([eatDate, slot])
}

model Menu {
  id          String   @id @default(cuid())
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items MenuItem[]
}

model MenuItem {
  id          String     @id @default(cuid())
  menuId      String
  menu        Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  name        String
  description String?
  /// Price per `unit` (e.g. TZS per kg of nyama, or per plate)
  price       Decimal    @db.Decimal(12, 2)
  unit        String     @default("PIECE")
  imageUrl    String?
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])
  /// Which slots this dish is available (breakfast/lunch/dinner)
  mealSlots   MealSlot[]
  available   Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  orderItems OrderItem[]
  hotPicks   HotPickManual[]
}

/// Per-module config: show hot/trending items (auto from orders or manual picks)
model HotProductsConfig {
  module       BusinessModule @id
  enabled      Boolean        @default(false)
  mode         HotPickMode    @default(AUTO)
  maxItems     Int            @default(8)
  /// AUTO: how many days of order history to rank
  lookbackDays Int            @default(30)
  updatedAt    DateTime       @updatedAt
}

/// Admin-curated hot picks (used when mode = MANUAL)
model HotPickManual {
  id         String         @id @default(cuid())
  module     BusinessModule
  productId  String?
  product    Product?       @relation(fields: [productId], references: [id], onDelete: Cascade)
  menuItemId String?
  menuItem   MenuItem?      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  sortOrder  Int            @default(0)
  badge      String?
  active     Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([productId])
  @@unique([menuItemId])
}

/// Kitchen prep queue for restaurant daily orders
model KitchenQueue {
  id        String             @id @default(cuid())
  orderId   String             @unique
  order     Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  mealSlot  MealSlot
  position  Int                @default(0)
  status    KitchenQueueStatus @default(WAITING)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}
